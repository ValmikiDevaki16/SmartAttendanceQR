<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.SmartAttendanceQR" parent="Theme.MaterialComponents.NoActionBar">
        <item name="colorPrimary">@color/indigo</item>
        <item name="colorPrimaryVariant">@color/indigo_dark</item>
        <item name="colorSecondary">@color/emerald</item>
        <item name="colorSecondaryVariant">@color/emerald_dark</item>
        <item name="colorSurface">@color/bg_card</item>
        <item name="colorError">@color/rose</item>
        <item name="android:colorBackground">@color/bg_deep</item>
        <item name="android:windowBackground">@color/bg_deep</item>
        <item name="android:statusBarColor">@color/bg_deep</item>
        <item name="android:navigationBarColor">@color/bg_deep</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">false</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>

        <!-- TextInputLayout dark styling -->
        <item name="textInputStyle">@style/DarkTextInput</item>
    </style>

    <style name="DarkTextInput" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/bg_elevated</item>
        <item name="boxStrokeColor">@color/indigo</item>
        <item name="hintTextColor">@color/text_indigo</item>
        <item name="android:textColorHint">@color/text_muted</item>
    </style>

    <!-- Splash screen theme -->
    <style name="Theme.SmartAttendanceQR.Splash" parent="Theme.SmartAttendanceQR">
        <item name="android:windowBackground">@color/bg_deep</item>
    </style>
</resources>